{
  "profileId": "ssh-foundations-template",
  "runnerKind": "ssh",
  "description": "Template profile for future SSH-backed Playground external compute.",
  "budgets": {
    "maxRuntimeSeconds": 1800,
    "maxOutputBytes": 1048576
  },
  "ssh": {
    "hostAlias": "replace-with-your-ssh-config-alias",
    "remoteWorkspaceRoot": "/home/replace-with-user/calcwiz-playground",
    "remoteProjectPath": "/home/replace-with-user/calcwiz-playground/Calculator",
    "remoteShell": "bash"
  },
  "reliability": {
    "preflightTimeoutSeconds": 15,
    "uploadTimeoutSeconds": 30,
    "remoteRunTimeoutSeconds": 120,
    "pullbackTimeoutSeconds": 30,
    "uploadRetries": 1,
    "pullbackRetries": 1
  }
}
